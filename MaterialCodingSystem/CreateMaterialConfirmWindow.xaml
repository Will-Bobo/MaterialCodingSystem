<Window x:Class="MaterialCodingSystem.CreateMaterialConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认创建主物料"
        Width="640"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <!-- 与 MainWindow.xaml 的 PrimaryButton 表现保持一致 -->
        <SolidColorBrush x:Key="Brush.Accent.Primary" Color="#2563EB"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Accent.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold" Text="请确认以下信息后再创建"/>

        <Border Grid.Row="1" Margin="0,12,0,0"
                BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8"
                Background="#FAFAFA" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#6B7280" Text="编码" VerticalAlignment="Center"/>
                <Border Grid.Row="0" Grid.Column="1"
                        Background="#EEF2FF" CornerRadius="8" Padding="10,8"
                        BorderBrush="#C7D2FE" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" Text="{Binding Code}"/>
                </Border>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Foreground="#6B7280" Text="规格号" VerticalAlignment="Center"/>
                <Border Grid.Row="1" Grid.Column="1" Margin="0,10,0,0"
                        Background="#EEF2FF" CornerRadius="8" Padding="10,8"
                        BorderBrush="#C7D2FE" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding Spec}"/>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Foreground="#6B7280" Text="规格描述" VerticalAlignment="Center"/>
                <Border Grid.Row="2" Grid.Column="1" Margin="0,10,0,0"
                        Background="#EEF2FF" CornerRadius="8" Padding="10,8"
                        BorderBrush="#C7D2FE" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding Description}"/>
                </Border>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,10,0,0" Foreground="#6B7280" Text="名称" VerticalAlignment="Center"/>
                <Border Grid.Row="3" Grid.Column="1" Margin="0,10,0,0"
                        Background="#EEF2FF" CornerRadius="8" Padding="10,8"
                        BorderBrush="#C7D2FE" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding Name}"/>
                </Border>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,10,0,0" Foreground="#6B7280" Text="品牌" VerticalAlignment="Center"/>
                <Border Grid.Row="4" Grid.Column="1" Margin="0,10,0,0"
                        Background="#EEF2FF" CornerRadius="8" Padding="10,8"
                        BorderBrush="#C7D2FE" BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock FontWeight="SemiBold" TextWrapping="Wrap" Text="{Binding Brand, TargetNullValue=—}"/>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,14,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="120" Height="48" Margin="0,0,12,0"
                    Style="{StaticResource PrimaryButton}"
                    Content="取消" IsCancel="True"/>
            <Button Width="160" Height="48"
                    Style="{StaticResource PrimaryButton}"
                    Content="确认创建" IsDefault="True" Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>

