<Application x:Class="MaterialCodingSystem.App"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:local="clr-namespace:MaterialCodingSystem"
             xmlns:conv="clr-namespace:MaterialCodingSystem.Presentation.Converters">

    <Application.Resources>

        <ResourceDictionary>

            <!-- 全局 Converter：避免 UserControl 内 StaticResource 找不到 -->
            <conv:BomAuditStatusToVisibilityConverter x:Key="BomAuditStatusToVis"/>

            <ResourceDictionary.MergedDictionaries>

                <ResourceDictionary Source="Presentation/Resources/UiErrors.xaml"/>

                <ResourceDictionary Source="Presentation/Resources/UiStrings.xaml"/>

                <ResourceDictionary Source="Presentation/Resources/UiStyles.xaml"/>

            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>

    </Application.Resources>

</Application>

