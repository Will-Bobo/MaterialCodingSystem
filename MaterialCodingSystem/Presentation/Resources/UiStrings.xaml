<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <sys:String x:Key="Dialog.Title.Warning">提示</sys:String>
    <sys:String x:Key="Dialog.Title.Confirm">确认</sys:String>
    <sys:String x:Key="Confirm.DuplicateTitle">确认</sys:String>
    <sys:String x:Key="Confirm.DuplicateBody">检测到可能重复物料，仍然要创建新主料吗？&#x0a;&#x0a;「是」= 确认创建&#x0a;「否」= 返回查看候选</sys:String>
    <sys:String x:Key="Confirm.DeprecateTitle">确认</sys:String>
    <sys:String x:Key="Confirm.DeprecateBody">确认要废弃该编码吗？&#x0a;&#x0a;编码：{0}</sys:String>

    <sys:String x:Key="Info.CreateMaterial.Processing">处理中...</sys:String>
    <sys:String x:Key="Hint.SelectCategory">请先选择分类。</sys:String>
    <sys:String x:Key="Info.CreateMaterial.CreateSuccess">创建成功：{0}（spec_normalized={1}）</sys:String>
    <sys:String x:Key="Info.CreateMaterial.CandidateSimilarityPlaceholder">相似度：—（预留）</sys:String>

    <sys:String x:Key="Info.SpecState.Duplicate">重复</sys:String>
    <sys:String x:Key="Info.SpecState.Pending">待输入</sys:String>
    <sys:String x:Key="Info.SpecState.Normal">正常</sys:String>

    <sys:String x:Key="Info.Decision.IdleMessage">待检索</sys:String>
    <sys:String x:Key="Info.Decision.SearchingMessage">正在检索相似物料...</sys:String>
    <sys:String x:Key="Info.Decision.NoCandidateMessage">未发现匹配物料</sys:String>
    <sys:String x:Key="Info.Decision.HasCandidateMessage">检测到相似物料</sys:String>
    <sys:String x:Key="Info.Decision.ForcedCreateMessage">可创建新主料</sys:String>
    <sys:String x:Key="Info.Decision.HighRiskMessage">高相似风险</sys:String>

    <sys:String x:Key="Info.Candidate.PickCategoryAndKeyword">请选择分类并输入关键字。</sys:String>
    <sys:String x:Key="Info.Candidate.Searching">搜索中...</sys:String>
    <sys:String x:Key="Info.Candidate.PossibleDuplicateTop20">检测到可能重复物料（Top20）：共 {0} 条，请抉择</sys:String>
    <sys:String x:Key="Info.Candidate.NoMatchCanCreate">未发现匹配物料，可直接创建新主料</sys:String>

    <sys:String x:Key="Info.Replacement.Processing">处理中...</sys:String>
    <sys:String x:Key="Info.Replacement.LoadingGroupInfo">加载组信息中...</sys:String>
    <sys:String x:Key="Info.Replacement.GroupInfoSummary">category={0} serial={1} 已用suffix=[{2}] 下一个={3}</sys:String>
    <sys:String x:Key="Info.Replacement.GroupCodeDisplay">主档：{0}{1:D7}</sys:String>
    <sys:String x:Key="Info.Replacement.ExistingSuffixNone">已有替代料: （无）</sys:String>
    <sys:String x:Key="Info.Replacement.ExistingSuffixList">已有替代料: {0}</sys:String>
    <sys:String x:Key="Info.Replacement.NextSuffixDisplay">将创建: {0}</sys:String>
    <sys:String x:Key="Info.Replacement.CreateHint">该物料将作为该组的替代料（suffix = {0}）</sys:String>
    <sys:String x:Key="Info.Replacement.ResolvedGroup">已定位：{0}</sys:String>
    <sys:String x:Key="Info.Replacement.CreateSuccess">创建成功：{0}（suffix={1}）</sys:String>
    <sys:String x:Key="Info.Replacement.EmbeddedSearchSearching">搜索中...</sys:String>
    <sys:String x:Key="Info.Replacement.EmbeddedSearchEmpty">未找到匹配的编码。</sys:String>
    <sys:String x:Key="Info.Replacement.EmbeddedSearchCount">共 {0} 条。</sys:String>

    <sys:String x:Key="Info.Search.SearchingCode">搜索中...</sys:String>
    <sys:String x:Key="Info.Search.SearchingSpec">搜索中...</sys:String>
    <sys:String x:Key="Info.Search.SelectSpecRowFirst">请先在 Top20 结果中选择一条。</sys:String>
    <sys:String x:Key="Info.Search.MissingCodeForJump">缺少编码，无法跳转。</sys:String>
    <sys:String x:Key="Info.Search.CodeDone">完成：{0} 条</sys:String>
    <sys:String x:Key="Info.Search.SpecDone">完成：{0} 条（Top20）</sys:String>

    <sys:String x:Key="Info.Deprecate.Processing">处理中...</sys:String>
    <sys:String x:Key="Info.Deprecate.Done">已废弃：{0}</sys:String>
    <sys:String x:Key="Info.Export.Processing">处理中...</sys:String>
    <sys:String x:Key="Info.Export.Cancelled">已取消。</sys:String>
    <sys:String x:Key="Info.Export.Success">导出成功：{0}（{1} 行，{2} 个分类 Sheet）</sys:String>
</ResourceDictionary>
