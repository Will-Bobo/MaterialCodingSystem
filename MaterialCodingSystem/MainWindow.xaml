<Window x:Class="MaterialCodingSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:MaterialCodingSystem.Presentation.Converters"
        mc:Ignorable="d"
        Title="Material Coding System" Height="720" Width="1020">
    <Window.Resources>
        <SolidColorBrush x:Key="Brush.Primary" Color="#2563EB"/>
        <SolidColorBrush x:Key="Brush.App.Background" Color="#F3F3F3"/>
        <SolidColorBrush x:Key="Brush.Field.Error" Color="#DC2626"/>
        <SolidColorBrush x:Key="Brush.Text.Muted" Color="#6B7280"/>
        <SolidColorBrush x:Key="Brush.Accent.Primary" Color="#2563EB"/>
        <SolidColorBrush x:Key="Brush.Border.Subtle" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="Brush.Overlay.Loading" Color="#99FFFFFF"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:StatusToIsActiveBoolConverter x:Key="StatusToIsActiveBool"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrush"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CandidateCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Brush.Accent.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,6"/>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
        </Style>
        <Style x:Key="CandidateListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <!-- 性能：候选项多时开启虚拟化 + 回收，提升滚动流畅度 -->
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CandidateListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBd" Background="Transparent" BorderThickness="2" CornerRadius="8" Padding="0" Margin="0,0,0,4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="BorderBrush" Value="{StaticResource Brush.Accent.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <TabControl Margin="12" SelectedIndex="{Binding SelectedTabIndex}">
            <TabItem Header="新建主物料(A)">
                <Grid Background="{StaticResource Brush.App.Background}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="380"/>
                        <ColumnDefinition Width="3*" MinWidth="520"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="新建主物料" Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

                                    <Border BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="分类" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <ComboBox Style="{StaticResource ModernComboBox}"
                                                      ItemsSource="{Binding CreateMaterial.Categories}"
                                                      SelectedItem="{Binding CreateMaterial.SelectedCategory}"
                                                      Margin="0,0,0,8">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock>
                                                            <Run Text="{Binding Code}"/>
                                                            <Run Text=" - "/>
                                                            <Run Text="{Binding Name}"/>
                                                        </TextBlock>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Padding="12,4" Content="刷新" Command="{Binding CreateMaterial.RefreshCategoriesCommand}"/>
                                                <Button Padding="12,4" Margin="8,0,0,0" Content="新增分类…" Command="{Binding CreateMaterial.OpenAddCategoryCommand}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="规格号（型号）" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{StaticResource Brush.Text.Muted}" FontSize="11" Margin="0,4,0,0" Text="填写供应商型号（如 CL10A106KP8NNNC）"/>
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     GotFocus="SpecField_OnGotFocus"
                                                     Margin="0,4,0,0"
                                                     Text="{Binding CreateMaterial.Spec, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Foreground="{StaticResource Brush.Field.Error}" FontSize="11" TextWrapping="Wrap" Text="{Binding CreateMaterial.SpecFieldError}"/>
                                            <TextBlock Margin="0,6,0,0" FontSize="11" Foreground="{StaticResource Brush.Text.Muted}">
                                                <Run Text="输入状态："/>
                                                <Run Text="{Binding CreateMaterial.SpecInputStateHint, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="规格描述" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{StaticResource Brush.Text.Muted}" FontSize="11" Margin="0,4,0,0" Text="填写完整规格（如 10uF 16V 0603 X5R）"/>
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     GotFocus="DescriptionField_OnGotFocus"
                                                     Margin="0,4,0,0"
                                                     Text="{Binding CreateMaterial.Description, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>

                                    <Border BorderBrush="{StaticResource Brush.Border.Subtle}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="名称" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource Brush.Text.Muted}"
                                                       Text="{Binding CreateMaterial.SelectedCategory.Name, FallbackValue=（未选择分类）}"/>
                                            <TextBlock Text="品牌" FontWeight="SemiBold" Margin="0,12,0,0"/>
                                            <TextBox Style="{StaticResource ModernTextBox}"
                                                     Margin="0,4,0,0" Text="{Binding CreateMaterial.Brand, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Foreground="{StaticResource Brush.Field.Error}" TextWrapping="Wrap" Text="{Binding CreateMaterial.GlobalError}"/>
                                </StackPanel>
                            </ScrollViewer>

                            <StackPanel Grid.Row="1" Margin="0,16,0,0">
                                <Button Content="创建主物料"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding CreateMaterial.CreateCommand}"/>
                                <TextBlock TextWrapping="Wrap" Text="{Binding CreateMaterial.Result}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <Grid MinHeight="380">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="候选决策" Style="{StaticResource TitleText}"/>
                            </StackPanel>

                            <Border Grid.Row="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,8">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource Brush.Border.Subtle}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CreateMaterial.State}" Value="CandidateConflict">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CreateMaterial.State}" Value="MissingRequiredFields">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding CreateMaterial.State}" Value="ReadyToCreate">
                                                <Setter Property="Background" Value="#ECFDF5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                                <Setter Property="Text" Value=""/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding CreateMaterial.State}" Value="CandidateConflict"/>
                                                            <Condition Binding="{Binding CreateMaterial.HasExactSpecMatch}" Value="True"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                        <Setter Property="Text" Value="已存在完全相同规格物料，请使用替代料。"/>
                                                    </MultiDataTrigger>

                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding CreateMaterial.State}" Value="CandidateConflict"/>
                                                            <Condition Binding="{Binding CreateMaterial.HasExactSpecMatch}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                        <Setter Property="Text" Value="检测到相似物料，如仍需新建请点击“允许新建”。"/>
                                                    </MultiDataTrigger>

                                                    <DataTrigger Binding="{Binding CreateMaterial.State}" Value="MissingRequiredFields">
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                        <Setter Property="Text" Value="⚠ 规格描述、品牌为必填项，请补充后再创建。"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CreateMaterial.State}" Value="Empty">
                                                        <Setter Property="Text" Value="请输入规格号开始查重。"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CreateMaterial.State}" Value="ReadyToCreate">
                                                        <Setter Property="Text" Value="已满足创建条件，请点击“创建主物料”。"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" CornerRadius="6" Padding="12,10" Margin="0,0,0,8"
                                    BorderThickness="1"
                                    Background="{Binding CreateMaterial.DecisionInfoBarBackground}"
                                    BorderBrush="{Binding CreateMaterial.DecisionInfoBarBorderBrush}"
                                    Visibility="{Binding CreateMaterial.ShowAllowCreatePanel, Converter={StaticResource BoolToVis}}">
                                <StackPanel>
                                    <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="⚠" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{StaticResource Brush.Accent.Primary}"/>
                                    <TextBlock Grid.Column="1" Text="请选择处理方式" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Content="生成替代料"
                                                Style="{StaticResource PrimaryButton}"
                                                Command="{Binding CreateMaterial.UseCandidateAsReplacementCommand}"
                                                CommandParameter="{Binding CreateMaterial.SelectedCandidate}"/>
                                        <Button Content="允许新建（下一步点击创建）"
                                                Margin="8,0,0,0"
                                                Padding="12,6"
                                                Command="{Binding CreateMaterial.ForceCreateWithConfirmCommand}"
                                                Visibility="{Binding CreateMaterial.HasExactSpecMatch, Converter={StaticResource InverseBoolToVis}}"/>
                                    </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,6,0,0"
                                               FontSize="11"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}"/>
                                                <Setter Property="Text" Value=""/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateMaterial.State}" Value="MissingRequiredFields">
                                                        <Setter Property="Foreground" Value="Orange"/>
                                                        <Setter Property="Text" Value="⚠ 规格描述、品牌为必填项，请补充后再创建。"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding CreateMaterial.IsForceCreateAllowed}" Value="True">
                                                        <Setter Property="Text" Value="已允许新建。"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <Grid Grid.Row="3" Margin="0,0,0,0">
                                <ListBox Panel.ZIndex="0"
                                         Style="{StaticResource CandidateListBox}"
                                         ItemContainerStyle="{StaticResource CandidateListBoxItem}"
                                         ItemsSource="{Binding CreateMaterial.CandidateItems}"
                                         SelectedItem="{Binding CreateMaterial.SelectedCandidate, Mode=TwoWay}"
                                         Visibility="{Binding CreateMaterial.ShowCandidateCardList, Converter={StaticResource BoolToVis}}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CandidateCardStyle}"
                                                    Padding="10"
                                                    Margin="0,4">

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 左侧内容 -->
                                                    <StackPanel>

                                                        <!-- 第一行：Code + 状态 + 操作 -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Code（主标题） -->
                                                            <TextBlock Text="{Binding Code}"
                                                                    FontSize="15"
                                                                    FontWeight="Bold"
                                                                    VerticalAlignment="Center"/>

                                                            <!-- 相似度 -->
                                                            <Border Grid.Column="1"
                                                                    Background="#FEF3C7"
                                                                    CornerRadius="4"
                                                                    Padding="4,1"
                                                                    Margin="8,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock FontSize="10"
                                                                        Text="{Binding DataContext.CreateMaterial.CandidateSimilarityPlaceholder,
                                                                                RelativeSource={RelativeSource AncestorType=Window}}"/>
                                                            </Border>

                                                            <!-- 操作按钮 -->
                                                            <Button Grid.Column="2"
                                                                    Content="生成替代料"
                                                                    Style="{StaticResource PrimaryButton}"
                                                                    Padding="8,4"
                                                                    Margin="8,0,0,0"
                                                                    Command="{Binding DataContext.CreateMaterial.UseCandidateAsReplacementCommand,
                                                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>

                                                        <!-- 第二行：Spec -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="规格:"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource Brush.Text.Muted}"/>
                                                            <TextBlock Margin="4,0,0,0" Foreground="{StaticResource Brush.Primary}">
                                                                <Run Text="{Binding SpecPrefix, Mode=OneWay}"/>
                                                                <Run Text="{Binding SpecMatch, Mode=OneWay}">
                                                                    <Run.Style>
                                                                        <Style TargetType="Run">
                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource Brush.Primary}"/>
                                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding HasMatch}" Value="True">
                                                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                                                    <Setter Property="Foreground" Value="#DC2626"/>
                                                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Run.Style>
                                                                </Run>
                                                                <Run Text="{Binding SpecSuffix, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- 第三行：Description -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="描述:"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource Brush.Text.Muted}"/>

                                                            <TextBlock Text="{Binding Description}"
                                                                    Margin="4,0,0,0"
                                                                    Foreground="{StaticResource Brush.Text.Muted}"
                                                                    TextTrimming="CharacterEllipsis"
                                                                    TextWrapping="NoWrap"
                                                                    Width="360"/>
                                                        </StackPanel>

                                                        <!-- 第四行：Name + Brand -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">

                                                            <TextBlock Text="名称:"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource Brush.Text.Muted}"/>

                                                            <TextBlock Text="{Binding Name}"
                                                                    Margin="4,0,12,0"/>

                                                            <TextBlock Text="品牌:"
                                                                    FontSize="11"
                                                                    Foreground="{StaticResource Brush.Text.Muted}"/>

                                                            <TextBlock Text="{Binding Brand}"
                                                                    Margin="4,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Panel.ZIndex="1" Background="Transparent" Visibility="{Binding CreateMaterial.ShowCandidateEmptyState, Converter={StaticResource BoolToVis}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                        <TextBlock Text="🔍" FontSize="36" HorizontalAlignment="Center"/>
                                        <TextBlock Text="输入规格号开始查重" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                        <TextBlock Text="仅支持规格号（型号）匹配" Foreground="{StaticResource Brush.Text.Muted}" HorizontalAlignment="Center" Margin="0,6,0,0" TextAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Panel.ZIndex="2" Background="{StaticResource Brush.Overlay.Loading}" Visibility="{Binding CreateMaterial.CandidateLoading, Converter={StaticResource BoolToVis}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
                                        <TextBlock Text="正在搜索..." FontWeight="SemiBold" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="新增替代料(B-Z)">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Row="0" Grid.ColumnSpan="2" Header="编码搜索（本页，前缀→模糊）" Margin="0,0,0,8">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Style="{StaticResource ModernTextBox}"
                                         Grid.Column="0" Width="260" Margin="0,0,8,0"
                                         Text="{Binding CreateReplacement.EmbeddedCodeKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2" Content="搜索" Padding="12,4" Command="{Binding CreateReplacement.EmbeddedCodeSearchCommand}"/>
                            </Grid>
                        </GroupBox>

                        <DataGrid Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding CreateReplacement.EmbeddedCodeResults}"
                                  AutoGenerateColumns="False" IsReadOnly="True" Margin="0,0,0,8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="180"/>
                                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
                                <DataGridTextColumn Header="规格号" Binding="{Binding Spec}" Width="200"/>
                                <DataGridTextColumn Header="规格描述" Binding="{Binding Description}" Width="*"/>
                                <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="120"/>
                                <DataGridTextColumn Header="状态" Width="80"
                                                    Binding="{Binding Status, Converter={StaticResource StatusToText}}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="操作" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="选用" Padding="8,2"
                                                    Command="{Binding DataContext.CreateReplacement.PickEmbeddedCodeHitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Foreground="DimGray" Margin="0,4,0,0"
                                   Text="{Binding CreateReplacement.CodeSearchStatus}"/>

                        <!-- 基准编码输入已移除：仅允许从“选用”或“搜索页跳转”进入 -->

                        <Border Grid.Row="5" Grid.ColumnSpan="2" Margin="0,10,0,8"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Background="#FAFAFA"
                                Padding="12">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="已选基准（只读）"/>
                                <TextBlock Margin="0,4,0,10"
                                           Foreground="{StaticResource Brush.Text.Muted}" FontSize="11"
                                           Text="用于确认“基于哪个基准物料”创建替代料，以及将创建的 suffix 归属。"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Foreground="{StaticResource Brush.Text.Muted}" Text="编码"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontWeight="Bold"
                                               Text="{Binding CreateReplacement.MasterCodeDisplay, FallbackValue=（未选择）}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,6,0,0" Foreground="{StaticResource Brush.Text.Muted}" Text="规格号"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"
                                               Text="{Binding CreateReplacement.AnchorSpec, FallbackValue=—}"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,6,0,0" Foreground="{StaticResource Brush.Text.Muted}" Text="规格描述"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="{Binding CreateReplacement.AnchorDescription, FallbackValue=—}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,6,0,0" Foreground="{StaticResource Brush.Text.Muted}" Text="名称"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,6,0,0"
                                               Text="{Binding CreateReplacement.CategoryDisplayName, FallbackValue=—}"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,6,0,0" Foreground="{StaticResource Brush.Text.Muted}" Text="品牌"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,6,0,0"
                                               Text="{Binding CreateReplacement.AnchorBrand, FallbackValue=—}"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,6,0,0" Foreground="{StaticResource Brush.Text.Muted}" Text="Suffix"/>
                                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,6,0,0">
                                        <TextBlock Foreground="DimGray"
                                                   Text="{Binding CreateReplacement.ExistingSuffixDisplay}"/>
                                        <TextBlock Foreground="Orange"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding CreateReplacement.NextSuffixDisplay}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="6" Grid.ColumnSpan="2" Margin="0,0,0,12"
                                Background="White"
                                BorderBrush="{StaticResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontWeight="SemiBold" Text="新建替代料"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" VerticalAlignment="Center" Text="规格号(spec)"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,10,0,0">
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding CreateReplacement.Spec, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Foreground="Red" FontWeight="SemiBold"
                                               Text="{Binding CreateReplacement[spec], Mode=OneWay}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="规格描述(desc)"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="8,8,0,0">
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding CreateReplacement.Description, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Foreground="Red" FontWeight="SemiBold"
                                               Text="{Binding CreateReplacement[description], Mode=OneWay}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="名称"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="8,8,0,0"
                                           Foreground="{StaticResource Brush.Text.Muted}"
                                           Text="{Binding CreateReplacement.CategoryDisplayName, FallbackValue=（请先选择基准物料）}"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="品牌"/>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="8,8,0,0">
                                    <TextBox Style="{StaticResource ModernTextBox}"
                                             Text="{Binding CreateReplacement.Brand, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Foreground="Red" FontWeight="SemiBold"
                                               Text="{Binding CreateReplacement[brand], Mode=OneWay}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Vertical" Margin="0,12,0,0">
                                    <TextBlock TextWrapping="Wrap" Foreground="DarkSlateGray" Margin="0,0,0,8"
                                               Text="{Binding CreateReplacement.ReplacementCreateHint}"/>
                                    <Button Width="140" HorizontalAlignment="Left" Content="创建替代料" Command="{Binding CreateReplacement.CreateCommand}"/>
                                    <TextBlock Margin="0,12,0,0" TextWrapping="Wrap" Text="{Binding CreateReplacement.Result}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="DarkSlateGray"/>
                                                <Setter Property="Background" Value="{x:Null}"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CreateReplacement.HasError}" Value="True">
                                                        <Setter Property="Foreground" Value="#B91C1C"/>
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                        <Setter Property="Padding" Value="8,6"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="搜索/废弃">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <CheckBox Grid.Row="0" Content="包含废弃" IsChecked="{Binding Search.IncludeDeprecated}" />

                    <GroupBox Grid.Row="1" Header="编码搜索（前缀→模糊）" Margin="0,8,0,0">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="关键字"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Grid.Column="1" Margin="8,0" Text="{Binding Search.CodeKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="搜索" Padding="12,4" Command="{Binding Search.SearchByCodeCommand}"/>
                        </Grid>
                    </GroupBox>

                    <DataGrid Grid.Row="3" Margin="0,8,0,0" ItemsSource="{Binding Search.CodeResults}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="200"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="规格号" Binding="{Binding Spec}" Width="*"/>
                            <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="120"/>
                            <DataGridTextColumn Header="状态" Width="80"
                                                Binding="{Binding Status, Converter={StaticResource StatusToText}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="操作" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="作为替代料" Padding="10,2"
                                                    Command="{Binding DataContext.Search.AddCodeHitAsReplacementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Margin="8,0,0,0" Content="废弃" Padding="10,2"
                                                    IsEnabled="{Binding Status, Converter={StaticResource StatusToIsActiveBool}}"
                                                    Command="{Binding DataContext.Search.DeprecateCodeHitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GroupBox Grid.Row="4" Header="规格搜索（category + LIKE Top20）" Margin="0,12,0,0">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="分类编码"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0">
                                <ComboBox Style="{StaticResource ModernComboBox}"
                                          Width="200"
                                          ItemsSource="{Binding Search.Categories}"
                                          SelectedItem="{Binding Search.SelectedCategory}"
                                          >
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock>
                                                <Run Text="{Binding Code}"/>
                                                <Run Text=" - "/>
                                                <Run Text="{Binding Name}"/>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <Button Margin="8,0,0,0" Padding="12,4" Content="刷新" Command="{Binding Search.RefreshCategoriesCommand}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="关键字"/>
                            <TextBox Style="{StaticResource ModernTextBox}"
                                     Grid.Column="3" Margin="8,0" Text="{Binding Search.SpecKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="4" Content="搜索" Padding="12,4" Command="{Binding Search.SearchBySpecCommand}"/>
                        </Grid>
                    </GroupBox>

                    <DataGrid Grid.Row="5" Margin="0,8,0,0" ItemsSource="{Binding Search.SpecResults}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.SelectedItem>
                            <Binding Path="Search.SelectedSpecResult" Mode="TwoWay"/>
                        </DataGrid.SelectedItem>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="200"/>
                            <DataGridTextColumn Header="规格号" Binding="{Binding Spec}" Width="260"/>
                            <DataGridTextColumn Header="规格描述" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="140"/>
                            <DataGridTextColumn Header="品牌" Binding="{Binding Brand}" Width="120"/>
                            <DataGridTextColumn Header="状态" Width="80"
                                                Binding="{Binding Status, Converter={StaticResource StatusToText}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource StatusToBrush}}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="操作" Width="220">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="作为替代料" Padding="10,2"
                                                    Command="{Binding DataContext.Search.AddSpecHitAsReplacementCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Margin="8,0,0,0" Content="废弃" Padding="10,2"
                                                    IsEnabled="{Binding Status, Converter={StaticResource StatusToIsActiveBool}}"
                                                    Command="{Binding DataContext.Search.DeprecateSpecHitCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" Text="{Binding Search.Message}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,12,0,0" VerticalAlignment="Center">
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Brush.Text.Muted}"
                                   Text="提示：请在表格行内点击“废弃”，已废弃行将禁用。"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="导出 Excel">
                <StackPanel Margin="24">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12"
                               Text="导出当前库中的全部物料（含已废弃）；按分类分 Sheet；列：编码、名称、规格描述、规格号、品牌、状态。"/>
                    <Button HorizontalAlignment="Left" Width="200" Padding="12,8" Content="导出到 Excel…" Command="{Binding Export.ExportCommand}"/>
                    <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" Text="{Binding Export.Result}"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
