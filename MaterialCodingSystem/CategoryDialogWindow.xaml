<Window x:Class="MaterialCodingSystem.CategoryDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增分类" Height="220" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="分类编码"/>
        <TextBox Grid.Row="0" Grid.Column="1" Margin="8,4" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="分类名称"/>
        <TextBox Grid.Row="1" Grid.Column="1" Margin="8,4" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

        <TextBlock Grid.Row="2" Grid.Column="1" Margin="8,4" Foreground="Red" TextWrapping="Wrap" Text="{Binding Error}"/>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Padding="16,6" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}"/>
            <Button Content="取消" Padding="16,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
