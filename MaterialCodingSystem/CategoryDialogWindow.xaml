<Window x:Class="MaterialCodingSystem.CategoryDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="新增分类" Width="420" MinHeight="200"
        SizeToContent="Height"
        Background="#F3F3F3"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DialogFormCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource DialogFormCardStyle}">
            <StackPanel>
                <TextBlock Text="新增分类" Style="{StaticResource TitleText}" Margin="0,0,0,16"/>

                <TextBlock Text="分类编码"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Margin="0,4,0,12" Text="{Binding Code, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="分类名称"/>
                <TextBox Style="{StaticResource ModernTextBox}"
                         Margin="0,4,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Margin="0,8,0,0" Foreground="Red" TextWrapping="Wrap" Text="{Binding Error}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Padding="16,6" Margin="0,0,8,0" IsDefault="True" Command="{Binding SaveCommand}"/>
            <Button Content="取消" Padding="16,6" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
